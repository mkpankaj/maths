[
  {"id":"pc-001","type":"mcq","text":"What does percentage mean?","hasLatex":false,"options":["Out of 1000","Out of 100","Out of 10","Out of 1"],"correctIndex":1,"explanation":"Percent means 'out of 100'","difficulty":1},
